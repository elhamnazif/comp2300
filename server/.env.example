# Copy this file to server/.env for local development.
# ./gradlew :server:run will load server/.env automatically if it exists.
# Existing shell environment variables still take precedence.

# Environment
ENV=development

# HTTP port
PORT=8080

# Database
DB_PATH=jdbc:sqlite:vita.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ISSUER=http://0.0.0.0:8080
JWT_AUDIENCE=http://0.0.0.0:8080
JWT_REALM=comp2300

# Set to "false" to disable dev auth bypass in development mode
DEV_AUTH_BYPASS=true

# Medical record encryption
# Optional in development; required in production if you do not want the dev fallback
# Must be base64 for exactly 32 bytes
# MEDICAL_RECORD_ENCRYPTION_KEY=

# Resend (Email)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Vita <noreply@yourdomain.com>
APP_NAME=Vita

# App Base URL (used in email links)
APP_BASE_URL=http://localhost:8080
